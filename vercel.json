{
  "version": 2,
  "rewrites": [
    {
      "source": "/analyze/(.*)",
      "destination": "/api/index"
    },
    {
      "source": "/analyze",
      "destination": "/api/index"
    },
    {
      "source": "/save-case",
      "destination": "/api/index"
    },
    {
      "source": "/((?!api/|assets/|favicon.ico|placeholder.svg|robots.txt|.*\\.[a-zA-Z0-9]+$).*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/index.js": {
      "maxDuration": 60,
      "memory": 1024
    }
  }
}
