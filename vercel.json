{
  "version": 2,
  "rewrites": [
    {
      "source": "/analyze",
      "destination": "/api/index"
    },
    {
      "source": "/rules",
      "destination": "/api/index"
    },
    {
      "source": "/save-case",
      "destination": "/api/index"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        }
      ]
    }
  ],
  "functions": {
    "api/index.js": {
      "maxDuration": 60,
      "memory": 1024
    }
  }
}
